cat > .gitignore << 'EOF'
# Gradle
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar

# Compiled files
*.class
*.jar
*.war
*.ear

# IDE files
.idea/
*.iml
.vscode/
.classpath
.project

# OS files
.DS_Store
Thumbs.db

# Application logs
*.log

# Local configuration
*.local.properties

# Docker volumes
data/
postgres-data/

# Node modules (if any frontend)
node_modules/
EOF